// BenihSaham Portfolio Tracking System
// Data Models v1.0 - 2026-04-16
// Based on Teguh Hidayat's value investing methodology

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum BsTransactionType {
  buy
  sell
  dividend
}

enum BsRecommendationType {
  buy
  hold
  wait
  reject
  sell
}

enum BsRatingType {
  poor
  fair
  good
  excellent
}

enum BsWatchlistStatus {
  watch
  deep_dive
  ready
  reject
}

enum BsPriorityType {
  low
  medium
  high
}

enum BsActionType {
  buy
  sell
  hold
  skip
}

enum BsContentType {
  article
  video
  newsletter
}

enum BsContentStatus {
  draft
  review
  published
  archived
}

enum BsPortfolioStatus {
  active
  closed
  archived
}

enum BsDividendType {
  cash
  stock
}

enum BsSubscriptionType {
  free
  premium
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

/// User accounts for authentication and portfolio ownership
model BsUser {
  id                String                @id @default(uuid())
  email             String                @unique
  name              String
  password          String?
  subscriptionType  BsSubscriptionType    @default(free)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  // Relations
  portfolios        BsPortfolio[]
  watchlistItems    BsWatchlistItem[]

  @@map("bs_users")
}

/// IDX-listed stock
model BsStock {
  id                String           @id @default(uuid())
  code              String           @unique
  name              String
  sector            String?
  industry          String?
  marketCap         BigInt?
  listedDate        DateTime?
  isIndexMember     Boolean          @default(false)
  ipoPrice          Decimal?         
  parValue          Decimal          @default(100) 
  sharesOutstanding BigInt?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  holdings          BsHolding[]
  transactions      BsTransaction[]
  valuations        BsValuation[]
  priceHistory      BsPriceHistory[]
  dividends         BsDividend[]
  watchlistItems    BsWatchlistItem[]
  decisionLogs      BsDecisionLog[]
  contentDrafts     BsContentDraft[]

  @@index([code])
  @@index([sector])
  @@index([isIndexMember])
  @@map("bs_stocks")
}

/// User portfolio containing holdings
model BsPortfolio {
  id                String             @id @default(uuid())
  userId            String
  name              String
  description       String?
  initialCapital    Decimal            
  currentValue      Decimal            @default(0) 
  totalReturn       Decimal            @default(0) 
  totalReturnPct    Decimal            @default(0) 
  status            BsPortfolioStatus  @default(active)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  user              BsUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings          BsHolding[]
  transactions      BsTransaction[]
  decisionLogs      BsDecisionLog[]

  @@index([userId])
  @@index([status])
  @@map("bs_portfolios")
}

/// Current position in a stock within a portfolio
model BsHolding {
  id                String       @id @default(uuid())
  portfolioId       String
  stockId           String
  shares            Int
  avgCost           Decimal      
  currentPrice      Decimal?     
  marketValue       Decimal?     
  unrealizedPnl     Decimal?     
  unrealizedPnlPct  Decimal?     
  dividendReceived  Decimal      @default(0) 
  firstBoughtAt     DateTime
  lastUpdatedAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  portfolio         BsPortfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock             BsStock      @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, stockId])
  @@index([portfolioId])
  @@index([stockId])
  @@map("bs_holdings")
}

/// Buy/sell transaction records
model BsTransaction {
  id                String             @id @default(uuid())
  portfolioId       String
  stockId           String
  type              BsTransactionType
  shares            Int
  price             Decimal            
  grossAmount       Decimal?           
  feeBrokerage      Decimal?           
  feeLevy           Decimal?           
  feeVat            Decimal?           
  netAmount         Decimal?           
  settlementDate    DateTime
  transactionAt     DateTime
  notes             String?
  decisionLogId     String?
  createdAt         DateTime           @default(now())

  // Relations
  portfolio         BsPortfolio        @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock             BsStock            @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([stockId])
  @@index([transactionAt])
  @@index([settlementDate])
  @@map("bs_transactions")
}

/// Valuation analysis following Teguh Hidayat's methodology
model BsValuation {
  id                    String                @id @default(uuid())
  stockId               String
  asOfDate              DateTime
  price                 Decimal               
  pbv                   Decimal?              
  roe                   Decimal?              
  bvps                  Decimal?              
  fv5yr                 Decimal?              
  fairValueMin          Decimal?              
  fairValueMax          Decimal?              
  marginOfSafetyPct     Decimal?              
  fundamentalRating     BsRatingType?
  managementRating      BsRatingType?
  recommendation        BsRecommendationType?
  thesis                String?
  risks                 String?
  catalysts             String?
  thesisBrokenTrigger   String?
  createdBy             String                @default("BIMA")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  // Relations
  stock                 BsStock               @relation(fields: [stockId], references: [id], onDelete: Cascade)
  decisionLogs          BsDecisionLog[]

  @@index([stockId])
  @@index([asOfDate])
  @@index([recommendation])
  @@map("bs_valuations")
}

/// Historical daily price data
model BsPriceHistory {
  id                String       @id @default(uuid())
  stockId           String
  date              DateTime
  open              Decimal?     
  high              Decimal?     
  low               Decimal?     
  close             Decimal      
  volume            BigInt?
  value             Decimal?     
  createdAt         DateTime     @default(now())

  // Relations
  stock             BsStock      @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId])
  @@index([date])
  @@index([stockId, date])
  @@map("bs_price_history")
}

/// Dividend payment history
model BsDividend {
  id                String         @id @default(uuid())
  stockId           String
  type              BsDividendType
  exDate            DateTime
  recordDate        DateTime?
  paymentDate       DateTime?
  amountPerShare    Decimal?       
  stockRatio        Decimal?       
  yieldPct          Decimal?       
  fiscalYear        Int?
  createdAt         DateTime       @default(now())

  // Relations
  stock             BsStock        @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
  @@index([exDate])
  @@index([paymentDate])
  @@map("bs_dividends")
}

/// Stocks being monitored for potential investment
model BsWatchlistItem {
  id                String            @id @default(uuid())
  userId            String
  stockId           String
  status            BsWatchlistStatus
  priority          BsPriorityType    @default(medium)
  thesis            String?
  triggerBuy        String?
  triggerSell       String?
  rejectReason      String?
  notes             String?
  addedAt           DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  user              BsUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock             BsStock           @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
  @@index([stockId])
  @@index([status])
  @@map("bs_watchlist_items")
}

/// Audit trail for investment decisions
model BsDecisionLog {
  id                String       @id @default(uuid())
  portfolioId       String?
  stockId           String
  action            BsActionType
  decisionDate      DateTime
  rationale         String
  valuationId       String?
  requiresApproval  Boolean      @default(false)
  approvedBy        String?
  approvalDate      DateTime?
  contentFriendly   Boolean      @default(true)
  createdAt         DateTime     @default(now())

  // Relations
  portfolio         BsPortfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  stock             BsStock      @relation(fields: [stockId], references: [id], onDelete: Cascade)
  valuation         BsValuation? @relation(fields: [valuationId], references: [id], onDelete: SetNull)
  contentDrafts     BsContentDraft[]

  @@index([portfolioId])
  @@index([stockId])
  @@index([decisionDate])
  @@map("bs_decision_logs")
}

/// Content drafts linked to investment analysis
model BsContentDraft {
  id                String             @id @default(uuid())
  stockId           String?
  decisionLogId     String?
  type              BsContentType
  title             String
  slug              String?
  status            BsContentStatus    @default(draft)
  educationalAngle  String?
  draftContent      String?
  publishedUrl      String?
  publishedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  stock             BsStock?           @relation(fields: [stockId], references: [id], onDelete: SetNull)
  decisionLog       BsDecisionLog?     @relation(fields: [decisionLogId], references: [id], onDelete: SetNull)

  @@index([stockId])
  @@index([status])
  @@index([publishedAt])
  @@map("bs_content_drafts")
}
