// BenihSaham Portfolio Tracking System
// Data Models v1.0 - 2026-04-16
// Based on Teguh Hidayat's value investing methodology

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum TransactionType {
  buy
  sell
  dividend
}

enum RecommendationType {
  buy
  hold
  wait
  reject
  sell
}

enum RatingType {
  poor
  fair
  good
  excellent
}

enum WatchlistStatus {
  watch
  deep_dive
  ready
  reject
}

enum PriorityType {
  low
  medium
  high
}

enum ActionType {
  buy
  sell
  hold
  skip
}

enum ContentType {
  article
  video
  newsletter
}

enum ContentStatus {
  draft
  review
  published
  archived
}

enum PortfolioStatus {
  active
  closed
  archived
}

enum DividendType {
  cash
  stock
}

enum SubscriptionType {
  free
  premium
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

/// User accounts for authentication and portfolio ownership
model User {
  id                String            @id @default(uuid())
  email             String            @unique
  name              String
  password          String?
  subscriptionType  SubscriptionType  @default(free)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  portfolios        Portfolio[]
  watchlistItems    WatchlistItem[]

  @@map("users")
}

/// IDX-listed stock
model Stock {
  id                String       @id @default(uuid())
  code              String(4)    @unique
  name              String
  sector            String?
  industry          String?
  marketCap         BigInt?
  listedDate        DateTime?
  isIndexMember     Boolean      @default(false)
  ipoPrice          Decimal?     @db.Decimal(10, 2)
  parValue          Decimal      @default(100) @db.Decimal(10, 2)
  sharesOutstanding BigInt?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  holdings          Holding[]
  transactions      Transaction[]
  valuations        Valuation[]
  priceHistory      PriceHistory[]
  dividends         Dividend[]
  watchlistItems    WatchlistItem[]
  decisionLogs      DecisionLog[]
  contentDrafts     ContentDraft[]

  @@index([code])
  @@index([sector])
  @@index([isIndexMember])
  @@map("stocks")
}

/// User portfolio containing holdings
model Portfolio {
  id                String          @id @default(uuid())
  userId            String
  name              String
  description       String?
  initialCapital    Decimal         @db.Decimal(15, 2)
  currentValue      Decimal         @default(0) @db.Decimal(15, 2)
  totalReturn       Decimal         @default(0) @db.Decimal(10, 2)
  totalReturnPct    Decimal         @default(0) @db.Decimal(6, 2)
  status            PortfolioStatus @default(active)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings          Holding[]
  transactions      Transaction[]
  decisionLogs      DecisionLog[]

  @@index([userId])
  @@index([status])
  @@map("portfolios")
}

/// Current position in a stock within a portfolio
model Holding {
  id                String       @id @default(uuid())
  portfolioId       String
  stockId           String
  shares            Int
  avgCost           Decimal      @db.Decimal(12, 2)
  currentPrice      Decimal?     @db.Decimal(12, 2)
  marketValue       Decimal?     @db.Decimal(15, 2)
  unrealizedPnl     Decimal?     @db.Decimal(15, 2)
  unrealizedPnlPct  Decimal?     @db.Decimal(6, 2)
  dividendReceived  Decimal      @default(0) @db.Decimal(15, 2)
  firstBoughtAt     DateTime
  lastUpdatedAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  portfolio         Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock             Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, stockId])
  @@index([portfolioId])
  @@index([stockId])
  @@map("holdings")
}

/// Buy/sell transaction records
model Transaction {
  id                String         @id @default(uuid())
  portfolioId       String
  stockId           String
  type              TransactionType
  shares            Int
  price             Decimal        @db.Decimal(12, 2)
  grossAmount       Decimal?       @db.Decimal(15, 2)
  feeBrokerage      Decimal?       @db.Decimal(15, 2)
  feeLevy           Decimal?       @db.Decimal(15, 2)
  feeVat            Decimal?       @db.Decimal(15, 2)
  netAmount         Decimal?       @db.Decimal(15, 2)
  settlementDate    DateTime
  transactionAt     DateTime
  notes             String?
  decisionLogId     String?
  createdAt         DateTime       @default(now())

  // Relations
  portfolio         Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  stock             Stock          @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([portfolioId])
  @@index([stockId])
  @@index([transactionAt])
  @@index([settlementDate])
  @@map("transactions")
}

/// Valuation analysis following Teguh Hidayat's methodology
model Valuation {
  id                    String              @id @default(uuid())
  stockId               String
  asOfDate              DateTime
  price                 Decimal             @db.Decimal(12, 2)
  pbv                   Decimal?            @db.Decimal(6, 2)
  roe                   Decimal?            @db.Decimal(6, 4)
  bvps                  Decimal?            @db.Decimal(12, 2)
  fv5yr                 Decimal?            @db.Decimal(12, 2)
  fairValueMin          Decimal?            @db.Decimal(12, 2)
  fairValueMax          Decimal?            @db.Decimal(12, 2)
  marginOfSafetyPct     Decimal?            @db.Decimal(6, 2)
  fundamentalRating     RatingType?
  managementRating      RatingType?
  recommendation        RecommendationType?
  thesis                String?
  risks                 String?
  catalysts             String?
  thesisBrokenTrigger   String?
  createdBy             String              @default("BIMA")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Relations
  stock                 Stock               @relation(fields: [stockId], references: [id], onDelete: Cascade)
  decisionLogs          DecisionLog[]

  @@index([stockId])
  @@index([asOfDate])
  @@index([recommendation])
  @@map("valuations")
}

/// Historical daily price data
model PriceHistory {
  id                String       @id @default(uuid())
  stockId           String
  date              DateTime
  open              Decimal?     @db.Decimal(12, 2)
  high              Decimal?     @db.Decimal(12, 2)
  low               Decimal?     @db.Decimal(12, 2)
  close             Decimal      @db.Decimal(12, 2)
  volume            BigInt?
  value             Decimal?     @db.Decimal(20, 2)
  createdAt         DateTime     @default(now())

  // Relations
  stock             Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, date])
  @@index([stockId])
  @@index([date])
  @@index([stockId, date])
  @@map("price_history")
}

/// Dividend payment history
model Dividend {
  id                String       @id @default(uuid())
  stockId           String
  type              DividendType
  exDate            DateTime
  recordDate        DateTime?
  paymentDate       DateTime?
  amountPerShare    Decimal?     @db.Decimal(10, 2)
  stockRatio        Decimal?     @db.Decimal(6, 4)
  yieldPct          Decimal?     @db.Decimal(6, 2)
  fiscalYear        Int?
  createdAt         DateTime     @default(now())

  // Relations
  stock             Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
  @@index([exDate])
  @@index([paymentDate])
  @@map("dividends")
}

/// Stocks being monitored for potential investment
model WatchlistItem {
  id                String          @id @default(uuid())
  userId            String
  stockId           String
  status            WatchlistStatus
  priority          PriorityType    @default(medium)
  thesis            String?
  triggerBuy        String?
  triggerSell       String?
  rejectReason      String?
  notes             String?
  addedAt           DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock             Stock           @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([userId, stockId])
  @@index([userId])
  @@index([stockId])
  @@index([status])
  @@map("watchlist_items")
}

/// Audit trail for investment decisions
model DecisionLog {
  id                String       @id @default(uuid())
  portfolioId       String?
  stockId           String
  action            ActionType
  decisionDate      DateTime
  rationale         String
  valuationId       String?
  requiresApproval  Boolean      @default(false)
  approvedBy        String?
  approvalDate      DateTime?
  contentFriendly   Boolean      @default(true)
  createdAt         DateTime     @default(now())

  // Relations
  portfolio         Portfolio?   @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  stock             Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  valuation         Valuation?   @relation(fields: [valuationId], references: [id], onDelete: SetNull)
  contentDrafts     ContentDraft[]

  @@index([portfolioId])
  @@index([stockId])
  @@index([decisionDate])
  @@map("decision_logs")
}

/// Content drafts linked to investment analysis
model ContentDraft {
  id                String        @id @default(uuid())
  stockId           String?
  decisionLogId     String?
  type              ContentType
  title             String
  slug              String?
  status            ContentStatus @default(draft)
  educationalAngle  String?
  draftContent      String?
  publishedUrl      String?
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  stock             Stock?        @relation(fields: [stockId], references: [id], onDelete: SetNull)
  decisionLog       DecisionLog?  @relation(fields: [decisionLogId], references: [id], onDelete: SetNull)

  @@index([stockId])
  @@index([status])
  @@index([publishedAt])
  @@map("content_drafts")
}
